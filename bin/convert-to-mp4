#!/usr/bin/env bash

DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=true; shift ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) DIR="$1"; shift ;;
  esac
done

if [[ -z "$DIR" ]]; then
  echo "Usage: $0 [--dry-run] <directory>" >&2
  exit 1
fi

if [[ ! -d "$DIR" ]]; then
  echo "Error: not a directory: $DIR" >&2
  exit 1
fi

COUNT_ALREADY_DONE=0
COUNT_MOVED_FROM_CONVERTED=0
COUNT_CONVERTED=0
COUNT_SKIPPED=0
COUNT_ERRORS=0

do_mkdir() {
  if [[ "$DRY_RUN" == true ]]; then
    echo "  [dry-run] mkdir -p '$1'"
  else
    mkdir -p "$1"
  fi
}

do_move() {
  if [[ "$DRY_RUN" == true ]]; then
    echo "  [dry-run] mv '$1' '$2'"
  else
    mv "$1" "$2"
  fi
}

while IFS= read -r -d $'\0' FILE; do
  PARENT="$(dirname "$FILE")"
  FILENAME="$(basename "$FILE")"
  BASE="${FILENAME%.*}"
  MP4="$PARENT/$BASE.mp4"
  CONVERTED_MP4="$PARENT/converted/$BASE.mp4"
  ORIG_FILE="$PARENT/orig/$FILENAME"

  if [[ -f "$ORIG_FILE" ]]; then
    echo "SKIP (already processed, found in orig/): $FILE"
    COUNT_SKIPPED=$(( COUNT_SKIPPED + 1 ))
    continue
  fi

  if [[ -f "$MP4" ]]; then
    echo "FOUND (mp4 exists alongside): $FILE"
    do_mkdir "$PARENT/orig"
    do_move "$FILE" "$ORIG_FILE"
    COUNT_ALREADY_DONE=$(( COUNT_ALREADY_DONE + 1 ))

  elif [[ -f "$CONVERTED_MP4" ]]; then
    echo "FOUND (mp4 in converted/ subdir): $FILE"
    do_mkdir "$PARENT/orig"
    do_move "$CONVERTED_MP4" "$MP4"
    do_move "$FILE" "$ORIG_FILE"
    COUNT_MOVED_FROM_CONVERTED=$(( COUNT_MOVED_FROM_CONVERTED + 1 ))

  else
    echo "CONVERTING: $FILE"
    if [[ "$DRY_RUN" == true ]]; then
      echo "  [dry-run] ffmpeg -i '$FILE' ... '$MP4'"
      do_mkdir "$PARENT/orig"
      do_move "$FILE" "$ORIG_FILE"
      COUNT_CONVERTED=$(( COUNT_CONVERTED + 1 ))
    else
      if ffmpeg -y -loglevel error -i "$FILE" \
          -c:v libx264 -crf 18 -preset fast -c:a aac "$MP4"; then
        do_mkdir "$PARENT/orig"
        do_move "$FILE" "$ORIG_FILE"
        COUNT_CONVERTED=$(( COUNT_CONVERTED + 1 ))
      else
        echo "  ERROR: conversion failed for $FILE"
        COUNT_ERRORS=$(( COUNT_ERRORS + 1 ))
      fi
    fi
  fi

done < <(find "$DIR" -type f \
  -not -path "*/orig/*" \
  -not -path "*/converted/*" \
  \( -iname "*.mpg" -o -iname "*.mpeg" -o -iname "*.avi" -o -iname "*.mov" \
     -o -iname "*.mkv" -o -iname "*.wmv" -o -iname "*.flv" -o -iname "*.m4v" \
     -o -iname "*.3gp" -o -iname "*.mts"  -o -iname "*.m2ts" -o -iname "*.ts" \
     -o -iname "*.webm" -o -iname "*.ogv"  -o -iname "*.vob" \) \
  -print0)

TOTAL=$(( COUNT_ALREADY_DONE + COUNT_MOVED_FROM_CONVERTED + COUNT_CONVERTED + COUNT_SKIPPED + COUNT_ERRORS ))

echo ""
echo "Summary (${DRY_RUN:+dry run, }$TOTAL files):"
echo "  Already converted (mp4 alongside):   $COUNT_ALREADY_DONE"
echo "  Moved from converted/ subdir:        $COUNT_MOVED_FROM_CONVERTED"
echo "  Newly converted:                     $COUNT_CONVERTED"
echo "  Skipped (already in orig/):          $COUNT_SKIPPED"
if [[ $COUNT_ERRORS -gt 0 ]]; then
echo "  Errors:                              $COUNT_ERRORS"
fi
