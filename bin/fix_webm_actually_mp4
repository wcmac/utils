#!/usr/bin/env python3
import os
import subprocess
import sys

def fix_extensions(directory, dry_run):
    for root, dirs, files in os.walk(directory):
        for filename in files:
            if filename.lower().endswith(".webm"):
                filepath = os.path.join(root, filename)
                try:
                    result = subprocess.run(
                        ['file', '--mime-type', '-b', filepath],
                        capture_output=True,
                        text=True
                    )
                    actual_type = result.stdout.strip()
                    if "video/mp4" in actual_type or "audio/mp4" in actual_type:
                        new_filepath = os.path.splitext(filepath)[0] + ".mp4"
                        if dry_run:
                            print(f"[DRY RUN] Would rename: {filename} -> {os.path.basename(new_filepath)}")
                        else:
                            os.rename(filepath, new_filepath)
                            print(f"Fixed: {filename} -> {os.path.basename(new_filepath)}")
                except Exception as e:
                    print(f"Error checking {filename}: {e}")

if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(description="Rename .webm files that are actually mp4s")
    parser.add_argument("directory", nargs="?", default=".", help="Directory to scan (default: current dir)")
    parser.add_argument("--dry-run", action="store_true", help="Show what would be renamed without making changes")
    args = parser.parse_args()

    if args.dry_run:
        print("--- DRY RUN: no changes will be made ---")
    fix_extensions(args.directory, args.dry_run)
    if args.dry_run:
        print("--- END DRY RUN ---")
